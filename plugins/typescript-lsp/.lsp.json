{
  "typescript": {
    "command": "node",
    "args": ["${CLAUDE_PLUGIN_DATA}/node_modules/typescript-language-server/lib/cli.mjs", "--stdio"],
    "env": {
      "NODE_PATH": "${CLAUDE_PLUGIN_DATA}/node_modules"
    },
    "extensionToLanguage": {
      ".ts": "typescript",
      ".tsx": "typescriptreact",
      ".js": "javascript",
      ".jsx": "javascriptreact",
      ".mts": "typescript",
      ".cts": "typescript",
      ".mjs": "javascript",
      ".cjs": "javascript"
    }
  }
}
